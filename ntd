-- ============================================

local function sendWebhook(t5Count)
    if WEBHOOK_URL == "" then return end
    
    local player = game.Players.LocalPlayer
    local username = player.Name
    local userId = player.UserId
    local gems = getGems()
    local counts = getPotionCounts()
    
    local data = {
        ["embeds"] = {{
            ["title"] = "🧪 T5 Potion Crafted!",
            ["color"] = 0x00ff00,
            ["fields"] = {
                { name = "👤 Username", value = username, inline = true },
                { name = "🆔 User ID", value = tostring(userId), inline = true },
                { name = "🎯 T5 Count", value = tostring(t5Count), inline = true },
                { name = "💎 Gems Remaining", value = tostring(gems), inline = true },
                { name = "📦 Inventory", value = string.format("T1:%d T2:%d T3:%d T4:%d", counts.T1, counts.T2, counts.T3, counts.T4), inline = false },
            },
            ["footer"] = { text = "Auto Crafter v2.2" },
            ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }
    
    pcall(function()
        local req = syn and syn.request or request or http_request
        if req then
            req({
                Url = WEBHOOK_URL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = game:GetService("HttpService"):JSONEncode(data)
            })
        end
    end)
end

-- ============================================
-- INVENTORY FUNCTIONS
-- ============================================

local function getPotionCounts()
    local counts = { T1 = 0, T2 = 0, T3 = 0, T4 = 0, T5 = 0 }
    local player = game.Players.LocalPlayer
    local potionsFolder = player:FindFirstChild("Potions")
    
    if potionsFolder then
        for _, child in ipairs(potionsFolder:GetChildren()) do
            local name = child.Name
            local value = child.Value or 0
            if name == "CoinsPotion1" then
                counts.T1 = value
            elseif name == "CoinsPotion2" then
                counts.T2 = value
            elseif name == "CoinsPotion3" then
                counts.T3 = value
            elseif name == "CoinsPotion4" then
                counts.T4 = value
            elseif name == "CoinsPotion5" then
                counts.T5 = value
            end
        end
    end
    return counts
end

local function getGems()
    local player = game.Players.LocalPlayer
    local gems = player:FindFirstChild("Gems")
    return gems and gems.Value or 0
end

local function getCraftPotion()
    local remotes = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
    local functions = remotes and remotes:FindFirstChild("Functions")
    return functions and functions:FindFirstChild("CraftPotion")
end

-- ============================================
-- CORRECT BACKWARD CALCULATION
-- ============================================

local function calculateMissingBackwards(targetT5)
    local current = getPotionCounts()
    
    local needT5 = math.max(0, targetT5 - current.T5)
    local needT4 = math.max(0, (targetT5 * 3) - current.T4)
    local needT3 = math.max(0, (needT4 * 3) - current.T3)
    local needT2 = math.max(0, (needT3 * 3) - current.T2)
    local needT1 = math.max(0, (needT2 * 3) - current.T1)
    
    return {
        T1 = needT1,
        T2 = needT2,
        T3 = needT3,
        T4 = needT4,
        T5 = needT5,
    }
end

