-- ============================================
-- HELPERS
-- ============================================

local function formatTime(seconds)
    if seconds <= 0 then return "0:00" end
    local mins = math.floor(seconds / 60)
    local secs = seconds % 60
    return string.format("%d:%02d", mins, secs)
end

local function formatNumber(num)
    if num >= 1000000 then
        return string.format("%.1fM", num / 1000000)
    elseif num >= 1000 then
        return string.format("%.1fK", num / 1000)
    end
    return tostring(num)
end

local function getPotionCounts()
    local counts = { T1 = 0, T2 = 0, T3 = 0, T4 = 0, T5 = 0 }
    local potions = LocalPlayer:FindFirstChild("Potions")
    if potions then
        for _, child in ipairs(potions:GetChildren()) do
            if child.Name == "CoinsPotion1" then
                counts.T1 = child.Value
            elseif child.Name == "CoinsPotion2" then
                counts.T2 = child.Value
            elseif child.Name == "CoinsPotion3" then
                counts.T3 = child.Value
            elseif child.Name == "CoinsPotion4" then
                counts.T4 = child.Value
            elseif child.Name == "CoinsPotion5" then
                counts.T5 = child.Value
            end
        end
    end
    return counts
end

local function getGems()
    local gems = LocalPlayer:FindFirstChild("Gems")
    return gems and gems.Value or 0
end

-- ============================================
-- CORRECT BACKWARD CALCULATION
-- ============================================

local function calculateMissing(targetT5)
    local current = getPotionCounts()
    
    local needT5 = math.max(0, targetT5 - current.T5)
    local needT4 = math.max(0, (needT5 * 3) - current.T4)
    local needT3 = math.max(0, (needT4 * 3) - current.T3)
    local needT2 = math.max(0, (needT3 * 3) - current.T2)
    local needT1 = math.max(0, (needT2 * 3) - current.T1)
    
    return { T1 = needT1, T2 = needT2, T3 = needT3, T4 = needT4, T5 = needT5 }
end

-- ============================================
-- TOTAL GEMS NEEDED (NEW!)
-- ============================================

local function calculateTotalGemsNeeded()
    local missing = calculateMissing(TARGET_T5)
    local total = 0
    total = total + (missing.T1 * GEM_COST.T1)
    total = total + (missing.T2 * GEM_COST.T2)
    total = total + (missing.T3 * GEM_COST.T3)
    total = total + (missing.T4 * GEM_COST.T4)
    total = total + (missing.T5 * GEM_COST.T5)
    return total
end

-- ============================================
-- REFILL QUEUE
-- ============================================

local function refreshQueue()
    local missing = calculateMissing(TARGET_T5)
    pendingQueue = {}
    
    for i = 1, missing.T1 do table.insert(pendingQueue, "T1") end
    for i = 1, missing.T2 do table.insert(pendingQueue, "T2") end
    for i = 1, missing.T3 do table.insert(pendingQueue, "T3") end
    for i = 1, missing.T4 do table.insert(pendingQueue, "T4") end
    
    return missing
end

local function getFreeSlots()
    local free = {}
    for i = 1, 3 do
        if not activeBrews[i] then
            table.insert(free, i)
        end
    end
    return free
end

local function brewNext()
    if #pendingQueue == 0 then
        refreshQueue()
    end
    
    if #pendingQueue == 0 then
        return false
    end
    
    local freeSlots = getFreeSlots()
    if #freeSlots == 0 then
        return false
    end
    
    local nextTier = table.remove(pendingQueue, 1)
    local remoteName = TIERS[nextTier]
    
    if CraftPotion and remoteName then
        local success = pcall(function()
            CraftPotion:InvokeServer(remoteName)
        end)
        
        if success then
            print("[Brew] Started:", nextTier, "- Remaining:", #pendingQueue)
            return true
        end
    end
    return false
end

