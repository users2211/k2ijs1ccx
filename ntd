local function updateGUI()
    local counts = getPotionCounts()
    local missing = calculateMissing(TARGET_T5)
    local totalGemsNeeded = calculateTotalGemsNeeded()
    local now = os.time()
    
    -- Update inventory
    invText.Text = string.format("T1:%d  T2:%d  T3:%d  T4:%d  T5:%d", counts.T1, counts.T2, counts.T3, counts.T4, counts.T5)
    
    -- Update needed display
    neededText.Text = string.format("T1:%d  T2:%d  T3:%d  T4:%d", missing.T1, missing.T2, missing.T3, missing.T4)
    
    -- Update total gems needed
    gemsNeededText.Text = formatNumber(totalGemsNeeded)
    if totalGemsNeeded > getGems() then
        gemsNeededText.Color = Color3.fromRGB(255, 100, 100)  -- Red if not enough
    else
        gemsNeededText.Color = Color3.fromRGB(100, 255, 100)  -- Green if enough
    end
    
    -- Update stats
    gemsText.Text = "💎 GEMS: " .. formatNumber(getGems())
    craftedText.Text = "🎯 T5 CRAFTED: " .. totalT5Crafted
    
    -- Update status
    if running then
        statusDot.Color = Color3.fromRGB(0, 255, 0)
        statusText.Text = "STATUS: ACTIVE"
        statusText.Color = Color3.fromRGB(100, 255, 100)
    else
        statusDot.Color = Color3.fromRGB(255, 0, 0)
        statusText.Text = "STATUS: IDLE"
        statusText.Color = Color3.fromRGB(255, 100, 100)
    end
    
    -- Update brewing slots
    local slots = { slot1Text, slot2Text, slot3Text }
    for i = 1, 3 do
        local brew = activeBrews[i]
        if brew and brew.endTime then
            local remaining = brew.endTime - now
            if remaining > 0 then
                slots[i].Text = string.format("Slot %d: %s (%s)", i, brew.tier, formatTime(remaining))
                slots[i].Color = Color3.fromRGB(255, 200, 100)
            else
                slots[i].Text = string.format("Slot %d: Empty", i)
                slots[i].Color = Color3.fromRGB(150, 150, 150)
            end
        else
            slots[i].Text = string.format("Slot %d: Empty", i)
            slots[i].Color = Color3.fromRGB(150, 150, 150)
        end
    end
    
    -- Update positions on resize
