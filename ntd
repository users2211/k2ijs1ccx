-- ============================================
-- CRAFTING FUNCTIONS
-- ============================================

local function craftTier(craftPotion, tier, amountNeeded, label)
    local crafted = 0
    local tierName = TIERS[tier].name
    local craftTime = TIERS[tier].time
    
    if amountNeeded <= 0 then
        return true
    end
    
    currentCraftingTier = label
    pcall(function() updateGUI() end)
    progressText.Text = string.format("Progress: 0%% (0/%d)", amountNeeded)
    
    while crafted < amountNeeded and _G.AutoBrew do
        local slotsToUse = math.min(CRAFTING_SLOTS, amountNeeded - crafted)
        
        for i = 1, slotsToUse do
            pcall(function()
                craftPotion:InvokeServer(tierName)
            end)
            task.wait(0.3)
        end
        
        task.wait(craftTime + 2)
        crafted = crafted + slotsToUse
        
        local percent = math.floor((crafted / amountNeeded) * 100)
        progressText.Text = string.format("Progress: %d%% (%d/%d)", percent, crafted, amountNeeded)
        pcall(function() updateGUI() end)
    end
    
    return true
end

-- Main batch function
local function craftBatch()
    local craftPotion = getCraftPotion()
    if not craftPotion then
        progressText.Text = "Error: Remote not found!"
        return false
    end
    
    local gems = getGems()
    local batchSize = math.min(BATCH_SIZE, math.floor(gems / 250))
    
    if batchSize == 0 then
        progressText.Text = "Out of gems!"
        return false
    end
    
    local missing = calculateMissingBackwards(batchSize)
    local current = getPotionCounts()
    
    if current.T5 >= batchSize then
        return true
    end
    
    -- Craft in correct order: T1 → T2 → T3 → T4 → T5
    if missing.T1 > 0 then
        if not craftTier(craftPotion, 1, missing.T1, "T1") then return false end
    end
    
    local newMissing = calculateMissingBackwards(batchSize)
    
    if newMissing.T2 > 0 then
        if not craftTier(craftPotion, 2, newMissing.T2, "T2") then return false end
    end
    
    newMissing = calculateMissingBackwards(batchSize)
    
    if newMissing.T3 > 0 then
        if not craftTier(craftPotion, 3, newMissing.T3, "T3") then return false end
    end
    
    newMissing = calculateMissingBackwards(batchSize)
    
    if newMissing.T4 > 0 then
        if not craftTier(craftPotion, 4, newMissing.T4, "T4") then return false end
    end
    
    currentCraftingTier = "T5"
    pcall(function() updateGUI() end)
    progressText.Text = string.format("Progress: 0%% (0/%d)", batchSize)
    
    local t5Crafted = 0
    while t5Crafted < batchSize and _G.AutoBrew do
        local slotsToUse = math.min(CRAFTING_SLOTS, batchSize - t5Crafted)
        
        for i = 1, slotsToUse do
            pcall(function()
                craftPotion:InvokeServer(TIERS[5].name)
            end)
            task.wait(0.3)
        end
        
        task.wait(TIERS[5].time + 2)
        t5Crafted = t5Crafted + slotsToUse
        totalT5Crafted = totalT5Crafted + slotsToUse
        
        -- Send webhook for each T5 crafted
        sendWebhook(totalT5Crafted)
        
        local percent = math.floor((t5Crafted / batchSize) * 100)
        progressText.Text = string.format("Progress: %d%% (%d/%d)", percent, t5Crafted, batchSize)
        pcall(function() updateGUI() end)
    end
    
    progressText.Text = "Batch complete!"
    return true
end

-- ============================================
-- MAIN LOOP
-- ============================================

local function start()
    if _G.AutoBrew then return end
    _G.AutoBrew = true
    pcall(function() updateGUI() end)
    
    while _G.AutoBrew do
        local success = craftBatch()
        if not success then
            _G.AutoBrew = false
            break
        end
        task.wait(10)
    end
    
    currentCraftingTier = "Idle"
    pcall(function() updateGUI() end)
end

local function stop()
    _G.AutoBrew = false
    currentCraftingTier = "Idle"
    progressText.Text = "Progress: Stopped"
    pcall(function() updateGUI() end)
    print("[Stopped] Auto Crafter")
end

